logs/
# Ignore logs
*.log

# Ignore Python cache
__pycache__/
*.pyc

# Ignore ML models (optional but recommended)
*.joblib

# Keep production ML service models versioned for deployment
!ml-service/data/saved_models/
!ml-service/data/saved_models/recommender.joblib
!ml-service/data/saved_models/risk_predictor.joblib

# Ignore local test scripts (run locally, don't commit)
**/test_*.py

# Ignore weird system files
nul